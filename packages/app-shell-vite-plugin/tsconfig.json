{
  "include": ["src", "rollup.config.js"],
  "exclude": ["node_modules", "dist", "**/tests/**"],

  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "noEmit": false,
    "noCheck": true,
    "sourceMap": false,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "dist"
  }
}
